# SIA hackathon demo — environment template
# Setup:   cp .env.example .env   then fill in the two secrets below.
# Run:     set -a && source .env && set +a && .venv/bin/sia --task_dir ./hackathon_demo/sql_task --max_gen 4 --sandbox none
#
# Billing: Meta/Feedback -> Claude (your subscription, via the OAuth token below).
#          Target NL->SQL + R2 classifier -> OSS models on Nebius (free credits).
#          No OpenAI provider is used; the `openai` SDK is just the Nebius wire protocol.

# --- Nebius Token Factory (OSS models: target NL->SQL + R2 classifier) ---
NEBIUS_API_KEY=your-nebius-api-key-here
NEBIUS_API_BASE=https://api.tokenfactory.nebius.com/v1/

# --- Claude (Meta + Feedback agentic loop) — billed to your Claude subscription ---
# Generate with:  claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=your-claude-code-oauth-token-here
# Alternative (pay-as-you-go API instead of subscription) — leave commented if using OAuth:
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- SIA framework overrides (read by Config.from_env) ---
SIA_BACKEND=claude
# Concrete Nebius OSS model id for the target NL->SQL call, resolved from the live
# catalog (GET /v1/models?verbose=true). e.g. google/gemma-3-27b-it or Qwen/Qwen3-30B-A3B-Instruct-2507
SIA_TASK_MODEL=
# R2 taxonomy classifier model — needs structured_outputs; separate from the target model.
R2_CLASSIFIER_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
